generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  VIEW_ONLY
  HIBERNATED
  BLOCKED
}

enum Role {
  USER
  ADMIN
}

enum Provider {
  MANUAL
  GOOGLE
  APPLE
}

enum Gender {
  MALE
  FEMALE
}

enum FriendshipStatus {
  ACCEPTED
  PENDING
}

model User{
  id String @id @default(uuid())
  email String @unique
  password String?
  isVerified Boolean @default(false)
  accountStatus AccountStatus @default(ACTIVE)
  role Role @default(USER)
  provider Provider @default(MANUAL)
  providerId String?  
  strikeCount Int @default(0)
  penaltyEndDate DateTime?
  lastEventAttendedDate DateTime?
  isPremium Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sentRequests          Connections[]    @relation("SenderRelation")
  receivedRequests      Connections[]    @relation("ReceiverRelation")
  blockedUsers          BlockList[]   @relation("BlockerRelation")
  blockedBy             BlockList[]   @relation("BlockedRelation")
  profile Profile?
  userTraits UserTraits?
  userPreference UserPreference?
  @@index([role])
}

model Profile {
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
  name String?
  age Int?
  gender Gender?
  location String?
  avatar String?
  bio String?
  profileInterest String[] @default([])
  countryVisited String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interest {
  id String @id @default(uuid())
  interestName String @unique
  interestIcon String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([interestName])
}


model UserTraits {
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
  energyScore Int
  curiosityScore Int
  rhythmScore Int
  createdAt DateTime @default(now())
  @@index([energyScore,curiosityScore,rhythmScore])
}

model UserPreference {
  id String @id @default(uuid())
  userId String @unique
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
  pushNotification Boolean @default(true)
  emailNotification Boolean @default(true)
  eventReminders Boolean @default(true)
  friendRequest Boolean @default(true)
}

model Connections{
  id String @id @default(uuid())
  senderId String
  sender User @relation("SenderRelation",fields: [senderId],references: [id],onDelete: Cascade)
  status FriendshipStatus
  receiverId String
  receiver   User     @relation("ReceiverRelation", fields: [receiverId], references: [id], onDelete: Cascade)
  @@unique([senderId, receiverId])
}

model BlockList{
  id String @id @default(uuid())
  blockerId String
  blocker User @relation("BlockerRelation",fields: [blockerId],references: [id],onDelete: Cascade)
  blockedUserId String
  blockedUser   User     @relation("BlockedRelation", fields: [blockedUserId], references: [id], onDelete: Cascade)
  @@unique([blockerId, blockedUserId])
}